        <mxCell id="title" value="Customer CRM Pipeline — How These 4 Skills Work Together" style="text;align=center;fontSize=20;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="200" y="20" width="1200" height="30" as="geometry"/></mxCell>
        <mxCell id="src1" value="M365 Calendar" style="rounded=1;fillColor=#f1f5f9;strokeColor=#94a3b8;" vertex="1" parent="1"><mxGeometry x="60" y="200" width="200" height="50" as="geometry"/></mxCell>
        <mxCell id="src2" value="Sent Emails" style="rounded=1;fillColor=#f1f5f9;strokeColor=#94a3b8;" vertex="1" parent="1"><mxGeometry x="60" y="268" width="200" height="50" as="geometry"/></mxCell>
        <mxCell id="src3" value="Teams Chat (SSP)" style="rounded=1;fillColor=#f1f5f9;strokeColor=#94a3b8;" vertex="1" parent="1"><mxGeometry x="60" y="336" width="200" height="50" as="geometry"/></mxCell>
        <mxCell id="src4" value="Git Repos" style="rounded=1;fillColor=#f1f5f9;strokeColor=#94a3b8;" vertex="1" parent="1"><mxGeometry x="60" y="404" width="200" height="50" as="geometry"/></mxCell>
        <mxCell id="dal" value="&lt;b&gt;/daily-activity-log&lt;/b&gt;&lt;br/&gt;Aggregates your day from M365, git, Teams.&lt;br/&gt;Writes one activity-log.md per project." style="rounded=1;fillColor=#eff6ff;strokeColor=#2563eb;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;" vertex="1" parent="1"><mxGeometry x="320" y="220" width="320" height="130" as="geometry"/></mxCell>
        <mxCell id="log" value="activity-log.md&#10;(per customer project)" style="shape=note;fillColor=#fffbeb;strokeColor=#d97706;align=center;" vertex="1" parent="1"><mxGeometry x="730" y="460" width="220" height="70" as="geometry"/></mxCell>
        <mxCell id="sync" value="&lt;b&gt;/crm-activity-sync&lt;/b&gt;&lt;br/&gt;Reads activity-log.md, creates milestone tasks in MSX. Idempotent, auto-joins deal teams." style="rounded=1;fillColor=#eff6ff;strokeColor=#2563eb;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;" vertex="1" parent="1"><mxGeometry x="1040" y="220" width="320" height="130" as="geometry"/></mxCell>
        <mxCell id="msx" value="&lt;b&gt;/msx-crm&lt;/b&gt;&lt;br/&gt;CRM tool layer (Node). Query accounts, opportunities, milestones, deal teams." style="rounded=1;fillColor=#f5f3ff;strokeColor=#7c3aed;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;" vertex="1" parent="1"><mxGeometry x="1040" y="470" width="320" height="130" as="geometry"/></mxCell>
        <mxCell id="cr" value="&lt;b&gt;/customer-repo&lt;/b&gt;&lt;br/&gt;Scaffolds the per-customer folder structure. Foundation used by all skills." style="rounded=1;fillColor=#ecfdf5;strokeColor=#10b981;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;" vertex="1" parent="1"><mxGeometry x="60" y="600" width="320" height="130" as="geometry"/></mxCell>
        <mxCell id="ext" value="&lt;b&gt;MSX&lt;/b&gt;&lt;br/&gt;Microsoft Sales Experience&lt;br/&gt;(Dynamics 365)" style="ellipse;fillColor=#fdf2f8;strokeColor=#db2777;" vertex="1" parent="1"><mxGeometry x="1100" y="670" width="200" height="100" as="geometry"/></mxCell>
