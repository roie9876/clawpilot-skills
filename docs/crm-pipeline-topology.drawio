  <diagram name="CRM Pipeline" id="crm-pipeline">
    <mxGraphModel dx="1600" dy="820" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="820" math="0" shadow="0">
      <root>
        <mxCell id="0" />
